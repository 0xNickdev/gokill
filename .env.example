# =============================================================================
# Islandr.io environment variables (deployment: Vercel frontend + Railway backend)
# Copy to .env for local dev. On Railway/Vercel, set these in the dashboard instead.
# =============================================================================

# ---- Railway service: API server (root directory = /) ----------------------
# PORT is injected by Railway automatically — do NOT set it yourself.
# Long random secret shared with the game server for server->API calls:
SERVER_DB_TOKEN=change-me-to-a-long-random-secret
# SQLite file path. Point this at a mounted Railway Volume so accounts survive redeploys:
DB_PATH=/data/players.db

# ---- Railway service: Game server (root directory = /server) ---------------
# PORT is injected by Railway automatically — do NOT set it yourself.
# Public HTTPS URL of the API service above (used to sync currency/kills):
API_URL=https://your-api-service.up.railway.app
# Must be the SAME value as the API server's SERVER_DB_TOKEN:
SERVER_DB_TOKEN=change-me-to-a-long-random-secret

# ---- Vercel (frontend) build env var ---------------------------------------
# Public host of the Railway GAME server, no protocol and no port.
# build-vercel.sh injects this into the "Server Address" input default.
GAME_SERVER_URL=your-game-service.up.railway.app
