{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"installCommand": "echo 'Skipping root install; client build installs its own deps'",
	"buildCommand": "bash scripts/build-vercel.sh",
	"outputDirectory": "dist",
	"rewrites": [
		{
			"source": "/api/:path*",
			"destination": "https://islandir-production.up.railway.app/api/:path*"
		},
		{ "source": "/loadout", "destination": "/loadout.html" },
		{ "source": "/deathMarker", "destination": "/deathMarker.html" }
	],
	"headers": [
		{
			"source": "/(.*)",
			"headers": [
				{ "key": "X-Frame-Options", "value": "SAMEORIGIN" },
				{ "key": "Referrer-Policy", "value": "same-origin" },
				{ "key": "X-XSS-Protection", "value": "1; mode=block" }
			]
		}
	]
}
